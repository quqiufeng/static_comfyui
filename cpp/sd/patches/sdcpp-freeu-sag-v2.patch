+        float weight = ipa.weight;
+        auto inject  = [&](SDCondition& c) {
+            if (c.c_crossattn.empty()) return;
+            auto old_shape = c.c_crossattn.shape();
+            int64_t ctx_dim = old_shape[0];
+            int64_t n_text  = old_shape[1];
+            int64_t batch   = 1;
+            if (old_shape.size() >= 3) {
+                batch = old_shape[2];
+                for (size_t i = 3; i < old_shape.size(); i++) batch *= old_shape[i];
+            }
+            const int64_t token_stride = n_text * batch;
+            const int64_t ipa_token_stride = n_ipa * batch;
+            std::vector<float> ipa_data(ctx_dim * ipa_token_stride, 0.0f);
+            int copy_dim = std::min(ipa_dim, (int)ctx_dim);
+            for (int b = 0; b < batch; b++) {
+                for (int t = 0; t < n_ipa; t++) {
+                    for (int d = 0; d < copy_dim; d++) {
+                        ipa_data[d * ipa_token_stride + t * batch + b] = ipa.tokens[t * ipa_dim + d] * weight;
+                    }
+                }
+            }
+            const float* old_data = c.c_crossattn.data();
+            std::vector<float> new_data(ctx_dim * (n_text + n_ipa) * batch);
+            std::copy(old_data, old_data + ctx_dim * token_stride, new_data.begin());
+            std::copy(ipa_data.begin(), ipa_data.end(), new_data.begin() + ctx_dim * token_stride);
+            auto new_shape = old_shape;
+            new_shape[1] = n_text + n_ipa;
+            c.c_crossattn = sd::Tensor<float>(new_shape, std::move(new_data));
+        };
+        inject(cond);
+        if (!uncond.empty()) {
+            inject(uncond);
+        }
+    }
