{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors",
      "clip_l_name": "clip_l.safetensors",
      "clip_g_name": "clip_g.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "clip_vision_vit_h_hidden.onnx"
    }
  },
  "3": {
    "class_type": "IPAdapterModelLoader",
    "inputs": {
      "ipadapter_file": "ipadapter_sdxl_plus_v3.onnx"
    }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "/data/models/image/demo_face_0.png"
    }
  },
  "5": {
    "class_type": "IPAdapterApply",
    "inputs": {
      "model": ["1", 0],
      "ipadapter": ["3", 0],
      "clip_vision": ["2", 0],
      "image_path": ["4", 0],
      "weight": 0.8
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "a red apple on a wooden table, photorealistic"
    }
  },
  "7": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["5", 0],
      "positive": ["6", 0],
      "negative": ["6", 0],
      "latent_image": ["7", 0],
      "seed": 42,
      "steps": 5,
      "cfg": 7.0,
      "sampler_name": "euler_a",
      "scheduler": "normal",
      "output_dir": "/tmp/comfy_output",
      "filename_prefix": "ipadapter_loader_test"
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["8", 0]
    }
  }
}
